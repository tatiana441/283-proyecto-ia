# API de MediWatch (FastAPI + agentes). Contexto de build: la raíz del repo.
#   docker build -f deployments/docker/Dockerfile.api -t mediwatch-api .

FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src ./src
COPY config ./config
COPY models/llm_rag ./models/llm_rag

EXPOSE 8000

# Railway inyecta PORT; localmente usa 8000
CMD uvicorn src.api.main:app --host 0.0.0.0 --port ${PORT:-8000}
